{
  "name": "asif-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install-all": "npm install && npm install --prefix frontend --legacy-peer-deps && npm install --prefix backend",
    "frontend": "npm run dev --prefix frontend",
    "backend": "npm start --prefix backend",
    "dev": "concurrently \"npm run frontend\" \"npm run backend\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
